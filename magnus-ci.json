{
  "language": "Node.js",
  "image": "mcr.microsoft.com/playwright:v1.45.0-jammy",
  "stages": {
    "setup": {
      "run": "npm install && npm --prefix backend install && npm --prefix frontend install"
    },
    "test-backend": {
      "run": "npm run test:backend",
      "needs": ["setup"]
    },
    "test-frontend": {
      "run": "npm run test:frontend",
      "needs": ["setup"]
    }
  }
}
