{
  "language": "Node.js",
  "image": "mcr.microsoft.com/playwright:v1.49.1",
  "stages": {
    "setup": {
      "run": "npm install && npm --prefix backend install && npm --prefix frontend install"
    },
    "test-backend": {
      "run": "npm run test:backend",
      "needs": ["setup"]
    },
    "test-frontend": {
      "run": "npm run test:frontend",
      "needs": ["setup"]
    },
    "test-e2e": {
      "run": "bash scripts/run-e2e-ci.sh",
      "needs": ["setup"]
    }
  }
}
